# Public domain and ACME email used by nginx/certbot.
DOMAIN=example.com
LETSENCRYPT_EMAIL=you@example.com

# Prebuilt application images (required on server with infra-only delivery).
BACKEND_IMAGE=backend:latest
BOT_IMAGE=bot:latest
ADMIN_FRONTEND_IMAGE=admin-panel:latest

# Runtime mode.
ENVIRONMENT=prod
LOG_LEVEL=INFO
RAG_DEBUG_LOG=false
ENABLE_DOCS_IN_PROD=false

# CORS for admin frontend origin.
CORS_ALLOW_ORIGINS=https://example.com
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS

# Backend auth and integration with bot.
JWT_SECRET=change_me_super_secret
BOT_API_TOKEN=change_me_backend_bot_token

# Telegram bot.
BOT_TOKEN=change_me_real_telegram_bot_token
BACKEND_BOT_TOKEN=change_me_backend_bot_token
BACKEND_URL=http://backend:8000
WEBHOOK_HOST=https://example.com
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8081
WEBHOOK_FROM_NGROK=false

# PostgreSQL.
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=boardgame_rules
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis.
REDIS_URL=redis://redis:6379/0

# Qdrant.
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# MinIO / S3.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=boardgame-rules
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change_me_minio_password

# LLM and embedding APIs.
# vLLM services run inside compose stack by default.
RAG_LLM__API_BASE=http://vllm-llm:8000/v1
RAG_EMBEDDING__API_BASE=http://vllm-embedding:8000/v1
RAG_LLM__MODEL=Qwen/Qwen2.5-7B-Instruct
RAG_EMBEDDING__MODEL=intfloat/multilingual-e5-base

# vLLM tuning.
VLLM_LLM_GPU_MEMORY_UTILIZATION=0.80
VLLM_LLM_MAX_MODEL_LEN=24576
VLLM_EMBEDDING_GPU_MEMORY_UTILIZATION=0.10
