# Infrastructure ports (host side)
BACKEND_PORT=8001
POSTGRES_HOST_PORT=5434
REDIS_PORT=6380
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003
MOCK_OPENAI_PORT=18080
MOCK_EMBEDDING_DIM=768

# Postgres
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame
POSTGRES_DB=boardgame_rules_test
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=boardgame-rules-test
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Backend
ENVIRONMENT=dev
JWT_SECRET=very_secret_key
BOT_API_TOKEN=integration-bot-token
RAG_DEBUG_LOG=false
LOG_LEVEL=INFO

# LLM/embedding mocked by mock-openai service
RAG_LLM__API_BASE=http://mock-openai:8080/v1
RAG_EMBEDDING__API_BASE=http://mock-openai:8080/v1
RAG_LLM__MODEL=mock-llm
RAG_EMBEDDING__MODEL=mock-embedding

# Integration tests auth bootstrap
INTEGRATION_ADMIN_USERNAME=integration_admin
INTEGRATION_ADMIN_PASSWORD=integration_admin_password
INTEGRATION_BOT_TOKEN=integration-bot-token

# Integration tests inside container network
INTEGRATION_BASE_URL=http://backend:8000
RUN_INTEGRATION_TESTS=1
