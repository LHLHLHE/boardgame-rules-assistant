# RAG
RAG_LLM__API_BASE=http://YOUR_VLLM_HOST:8010/v1
RAG_EMBEDDING__API_BASE=http://YOUR_VLLM_HOST:8011/v1
RAG_RETRIEVAL__MODE=hybrid
RAG_QDRANT__HYBRID_ENABLED=true
RAG_QDRANT__COLLECTION_NAME=boardgame_rules_hybrid

# Имена моделей на стороне vLLM (должны совпадать с сервером)
RAG_LLM__MODEL=Qwen/Qwen2.5-7B-Instruct
RAG_EMBEDDING__MODEL=intfloat/multilingual-e5-base

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=boardgame-rules

# PostgreSQL
POSTGRES_USER=boardgame
POSTGRES_PASSWORD=boardgame
POSTGRES_DB=boardgame_rules
POSTGRES_PORT=5432

# Backend / Celery
ENVIRONMENT=dev
JWT_SECRET=very_secret_key
BOT_API_TOKEN=very_secret_token
QDRANT_HOST=qdrant
QDRANT_PORT=6333
POSTGRES_HOST=postgres
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
RAG_DEBUG_LOG=true
LOG_LEVEL=DEBUG

# Бот
BOT_TOKEN="token"
# Публичный URL для setWebhook, если WEBHOOK_FROM_NGROK=false
WEBHOOK_HOST=http://localhost
WEBHOOK_FROM_NGROK=true
BACKEND_BOT_TOKEN=very_secret_token
BACKEND_URL=http://backend:8000
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8081
NGROK_AUTHTOKEN="token" # Для локального запуска с WebHook
NGROK_API_URL=http://ngrok:4040
